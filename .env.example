# Pick ONE provider. Both are OpenAI-compatible.
# OpenRouter free models, e.g. meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_KEY=sk-or-...

# NVIDIA NIM free tier, e.g. meta/llama-3.3-70b-instruct
NVIDIA_API_KEY=nvapi-...

# Optional: a personal access token raises GitHub search rate limits
# from 10 req/min unauthenticated to 30 req/min. The agent works without it.
GITHUB_TOKEN=

# Soft caps. Lower these if you're worried about quota.
OSINT_MAX_ITERATIONS=12
OSINT_PER_TOOL_TIMEOUT_S=30
